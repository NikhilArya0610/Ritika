<section class="rr-collection-page">
  <header class="rr-collection-page__header">
    <p class="rr-kicker">{{ 'collection.kicker' | t }}</p>
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <div>{{ collection.description }}</div>
    {% endif %}
  </header>
  {% paginate collection.products by 24 %}
    <div class="rr-product-grid">
      {% for product in collection.products %}
        {% render 'rr-product-card', product: product, show_vendor: false %}
      {% else %}
        <p>{{ 'collection.empty' | t }}</p>
      {% endfor %}
    </div>
    {% if paginate.pages > 1 %}
      <nav class="rr-pagination" aria-label="{{ 'collection.pagination' | t }}">
        {{ paginate | default_pagination }}
      </nav>
    {% endif %}
  {% endpaginate %}
</section>

{% stylesheet %}
  .rr-collection-page { width: var(--rr-page); margin: 0 auto; padding: clamp(34px, 7vw, 86px) 0; }
  .rr-collection-page__header { max-width: 780px; margin-bottom: 34px; }
  .rr-collection-page h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }
  .rr-collection-page__header div { color: var(--rr-muted); }
  .rr-product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .rr-card { background: #fffdf8; border-radius: 22px; overflow: hidden; box-shadow: 0 16px 40px rgba(24, 18, 15, 0.08); }
  .rr-card__media { display: block; aspect-ratio: 1 / 1.12; background: #eadcc8; overflow: hidden; }
  .rr-card__media img, .rr-card__placeholder { width: 100%; height: 100%; object-fit: cover; transition: scale 420ms ease; }
  .rr-card:hover .rr-card__media img { scale: 1.05; }
  .rr-card__body { padding: 16px; }
  .rr-card__body h3 { margin: 0 0 8px; font-size: 1rem; line-height: 1.25; }
  .rr-card__price, .rr-card__vendor { margin: 0; color: var(--rr-muted); }
  .rr-pagination { margin-top: 34px; text-align: center; }
  @media (max-width: 900px) { .rr-product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .rr-product-grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections_collection.name",
  "settings": []
}
{% endschema %}
