<section class="rr-search-page">
  <header>
    <p class="rr-kicker">{{ 'search.kicker' | t }}</p>
    <h1>{{ 'search.title' | t }}</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" class="rr-search-page__form">
      <label class="rr-visually-hidden" for="SearchInput">{{ 'search.label' | t }}</label>
      <input id="SearchInput" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'search.placeholder' | t }}">
      <button type="submit">{{ 'search.submit' | t }}</button>
    </form>
  </header>
  {% if search.performed %}
    <div class="rr-product-grid">
      {% for item in search.results %}
        {% if item.object_type == 'product' %}
          {% render 'rr-product-card', product: item, show_vendor: false %}
        {% endif %}
      {% else %}
        <p>{{ 'search.empty' | t }}</p>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .rr-search-page { width: var(--rr-page); margin: 0 auto; padding: clamp(40px, 8vw, 92px) 0; }
  .rr-search-page h1 {
    margin: 0 0 22px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }
  .rr-search-page__form { display: grid; grid-template-columns: 1fr auto; gap: 10px; max-width: 780px; margin-bottom: 36px; }
  .rr-search-page__form input {
    border: 1px solid rgba(24, 18, 15, 0.14);
    border-radius: 999px;
    padding: 15px 18px;
    background: #fffdf8;
  }
  .rr-search-page__form button {
    border: 0;
    border-radius: 999px;
    padding: 15px 22px;
    background: var(--rr-ink);
    color: var(--rr-paper);
    font-weight: 800;
    cursor: pointer;
  }
  .rr-product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .rr-card { background: #fffdf8; border-radius: 22px; overflow: hidden; box-shadow: 0 16px 40px rgba(24, 18, 15, 0.08); }
  .rr-card__media { display: block; aspect-ratio: 1 / 1.12; background: #eadcc8; overflow: hidden; }
  .rr-card__media img, .rr-card__placeholder { width: 100%; height: 100%; object-fit: cover; transition: scale 420ms ease; }
  .rr-card:hover .rr-card__media img { scale: 1.05; }
  .rr-card__body { padding: 16px; }
  .rr-card__body h3 { margin: 0 0 8px; font-size: 1rem; line-height: 1.25; }
  .rr-card__price, .rr-card__vendor { margin: 0; color: var(--rr-muted); }
  @media (max-width: 900px) { .rr-product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .rr-product-grid, .rr-search-page__form { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections_search.name",
  "settings": []
}
{% endschema %}
