<section class="rr-product-page">
  <div class="rr-product-page__media">
    {% if product.featured_image %}
      {{ product.featured_image | image_url: width: 1300 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 50vw, 94vw', widths: '600, 900, 1200, 1300', alt: product.title }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'rr-product-page__placeholder' }}
    {% endif %}
    {% if product.images.size > 1 %}
      <div class="rr-product-page__thumbs">
        {% for image in product.images limit: 4 %}
          {{ image | image_url: width: 220 | image_tag: loading: 'lazy', widths: '120, 180, 220', alt: product.title }}
        {% endfor %}
      </div>
    {% endif %}
  </div>
  <div class="rr-product-page__info">
    <p class="rr-kicker">{{ product.vendor }}</p>
    <h1>{{ product.title }}</h1>
    <p class="rr-product-page__price">{{ product.price | money }}</p>
    {% if product.description != blank %}
      <div class="rr-product-page__description">{{ product.description }}</div>
    {% endif %}
    {% form 'product', product, class: 'rr-product-form' %}
      {% if product.has_only_default_variant == false %}
        <label for="ProductSelect-{{ section.id }}">{{ 'product.variant_label' | t }}</label>
        <select id="ProductSelect-{{ section.id }}" name="id">
          {% for variant in product.variants %}
            <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
              {{ variant.title }}{% unless variant.available %} – {{ 'product.sold_out' | t }}{% endunless %}
            </option>
          {% endfor %}
        </select>
      {% else %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      {% endif %}
      <label for="Quantity-{{ section.id }}">{{ 'product.quantity' | t }}</label>
      <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
      <button type="submit" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
        {% if product.selected_or_first_available_variant.available %}
          {{ 'product.add_to_cart' | t }}
        {% else %}
          {{ 'product.sold_out' | t }}
        {% endif %}
      </button>
      {{ form | payment_button }}
    {% endform %}
    <div class="rr-product-page__promises">
      <span>{{ 'product.promise_gold' | t }}</span>
      <span>{{ 'product.promise_shipping' | t }}</span>
      <span>{{ 'product.promise_support' | t }}</span>
    </div>
  </div>
</section>

{% stylesheet %}
  .rr-product-page {
    width: var(--rr-page);
    margin: 0 auto;
    padding: clamp(34px, 7vw, 86px) 0;
    display: grid;
    grid-template-columns: 1.04fr 0.96fr;
    gap: clamp(24px, 5vw, 64px);
  }
  .rr-product-page__media {
    position: sticky;
    top: 104px;
    align-self: start;
  }
  .rr-product-page__media > img, .rr-product-page__placeholder {
    width: 100%;
    aspect-ratio: 1 / 1.08;
    object-fit: cover;
    border-radius: var(--rr-radius);
    background: var(--rr-soft);
    box-shadow: var(--rr-shadow);
  }
  .rr-product-page__thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 10px; }
  .rr-product-page__thumbs img { aspect-ratio: 1; object-fit: cover; border-radius: 14px; }
  .rr-product-page__info { padding-top: 18px; }
  .rr-product-page h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 5.5vw, 5.8rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }
  .rr-product-page__price { font-size: 1.35rem; color: var(--rr-ruby); font-weight: 800; }
  .rr-product-page__description { color: var(--rr-muted); }
  .rr-product-form { display: grid; gap: 12px; margin-top: 24px; }
  .rr-product-form select, .rr-product-form input {
    border: 1px solid rgba(24, 18, 15, 0.14);
    border-radius: 16px;
    padding: 13px 14px;
    background: #fffdf8;
  }
  .rr-product-form button {
    border: 0;
    border-radius: 999px;
    padding: 15px 22px;
    background: var(--rr-ink);
    color: var(--rr-paper);
    font-weight: 800;
    cursor: pointer;
  }
  .rr-product-form button:disabled { opacity: 0.55; cursor: not-allowed; }
  .rr-product-page__promises {
    display: grid;
    gap: 8px;
    margin-top: 22px;
    color: var(--rr-muted);
  }
  @media (max-width: 900px) {
    .rr-product-page { grid-template-columns: 1fr; }
    .rr-product-page__media { position: static; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections_product.name",
  "settings": []
}
{% endschema %}
