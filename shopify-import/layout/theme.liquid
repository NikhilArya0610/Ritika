<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}{% if current_tags %} - {{ current_tags | join: ', ' }}{% endif %}{% unless page_title contains 'Ritika Rajawat Fine Jewellery Atelier' %} - Ritika Rajawat Fine Jewellery Atelier{% endunless %}</title>
    <link rel="icon" type="image/png" href="{{ 'ritika_fevicon_logo_1.png' | asset_url }}">
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    <link rel="canonical" href="{{ canonical_url }}">
    {{ content_for_header }}
    <style>
      :root {
        --rr-ink: #000000;
        --rr-muted: #6f625a;
        --rr-paper: #f9f8f6;
        --rr-soft: #e4dfb5;
        --rr-gold: #b68a47;
        --rr-ruby: #3a050d;
        --rr-shadow: 0 24px 80px rgba(0, 0, 0, 0.12);
        --rr-radius: 28px;
        --rr-page: min(1180px, calc(100vw - 32px));
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        color: var(--rr-ink);
        background: var(--rr-paper);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.5;
      }
      img { max-width: 100%; height: auto; display: block; }
      a { color: inherit; text-decoration: none; }
      button, input, textarea, select { font: inherit; }
      .rr-skip {
        position: absolute;
        left: 16px;
        top: -80px;
        z-index: 20;
        background: var(--rr-ink);
        color: var(--rr-paper);
        padding: 12px 16px;
        border-radius: 999px;
      }
      .rr-skip:focus { top: 16px; }
      .rr-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(18px);
        background: var(--rr-ruby);
        color: var(--rr-paper);
        border-bottom: 1px solid rgba(249, 248, 246, 0.16);
      }
      .rr-header__inner {
        width: var(--rr-page);
        margin: 0 auto;
        min-height: 86px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 18px;
      }
      .rr-brand {
        display: grid;
        justify-items: center;
        gap: 4px;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(0.72rem, 1.2vw, 0.9rem);
        font-weight: 700;
        letter-spacing: 0;
        line-height: 1.1;
        text-align: center;
        text-transform: uppercase;
      }
      .rr-brand img {
        width: min(154px, 34vw);
      }
      .rr-nav {
        display: flex;
        align-items: center;
        gap: clamp(12px, 2vw, 28px);
        color: var(--rr-paper);
        font-size: 0.92rem;
      }
      .rr-nav--right { justify-content: flex-end; }
      .rr-nav a { transition: color 180ms ease; }
      .rr-nav a:hover, .rr-nav a:focus-visible { color: var(--rr-soft); }
      .rr-cart {
        border: 1px solid rgba(0, 0, 0, 0.16);
        border-radius: 999px;
        padding: 8px 14px;
      }
      main { min-height: 68vh; }
      .rr-footer {
        margin-top: 80px;
        background: var(--rr-ink);
        color: var(--rr-paper);
      }
      .rr-footer__inner {
        width: var(--rr-page);
        margin: 0 auto;
        padding: 54px 0;
        display: grid;
        grid-template-columns: 1.4fr repeat(3, 1fr);
        gap: 28px;
      }
      .rr-footer h2, .rr-footer h3 { margin: 0 0 12px; font-family: Georgia, "Times New Roman", serif; }
      .rr-footer p, .rr-footer a { color: rgba(255, 250, 242, 0.72); }
      .rr-footer ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
      .shopify-policy__container, .shopify-challenge__container { width: var(--rr-page); margin: 64px auto; }
      @media (max-width: 760px) {
        .rr-header__inner { grid-template-columns: 1fr; padding: 14px 0; }
        .rr-nav, .rr-nav--right { justify-content: center; flex-wrap: wrap; }
        .rr-footer__inner { grid-template-columns: 1fr; }
      }
      @media (prefers-reduced-motion: no-preference) {
        ::view-transition-old(root), ::view-transition-new(root) { animation-duration: 280ms; }
      }
    </style>
  </head>
  <body>
    <a class="rr-skip" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>
    <header class="rr-header">
      <div class="rr-header__inner">
        <nav class="rr-nav" aria-label="{{ 'general.primary_navigation' | t }}">
          <a href="/collections/best-seller">{{ 'navigation.best_sellers' | t }}</a>
          <a href="/collections/new-arrival">{{ 'navigation.new_arrivals' | t }}</a>
          <a href="/collections/rings">{{ 'navigation.rings' | t }}</a>
        </nav>
        <a class="rr-brand" href="{{ routes.root_url }}" aria-label="Ritika Rajawat Fine Jewellery Atelier">
          <img src="{{ 'ritika_logo.png' | asset_url }}" alt="Ritika Rajawat Fine Jewellery Atelier" width="1000" height="600">
          <span>Ritika Rajawat Fine Jewellery Atelier</span>
        </a>
        <nav class="rr-nav rr-nav--right" aria-label="{{ 'general.utility_navigation' | t }}">
          <a href="/pages/contact">{{ 'navigation.contact' | t }}</a>
          <a href="{{ routes.search_url }}">{{ 'navigation.search' | t }}</a>
          <a class="rr-cart" href="{{ routes.cart_url }}">{{ 'navigation.cart' | t: count: cart.item_count }}</a>
        </nav>
      </div>
    </header>
    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
    <footer class="rr-footer">
      <div class="rr-footer__inner">
        <section>
          <h2>{{ shop.name }}</h2>
          <p>{{ 'footer.summary' | t }}</p>
        </section>
        <section>
          <h3>{{ 'footer.shop' | t }}</h3>
          <ul>
            <li><a href="/collections/best-seller">{{ 'navigation.best_sellers' | t }}</a></li>
            <li><a href="/collections/new-arrival">{{ 'navigation.new_arrivals' | t }}</a></li>
            <li><a href="/collections/necklace">{{ 'navigation.necklaces' | t }}</a></li>
          </ul>
        </section>
        <section>
          <h3>{{ 'footer.support' | t }}</h3>
          <ul>
            <li><a href="/pages/contact">{{ 'navigation.contact' | t }}</a></li>
            <li><a href="{{ routes.search_url }}">{{ 'navigation.search' | t }}</a></li>
            <li><a href="{{ routes.cart_url }}">{{ 'navigation.cart_plain' | t }}</a></li>
          </ul>
        </section>
        <section>
          <h3>{{ 'footer.promise' | t }}</h3>
          <p>{{ 'footer.promise_text' | t }}</p>
        </section>
      </div>
    </footer>
  </body>
</html>
